# Optional configuration for dart_secrets_scanner.
# Copy this file to dart_secrets_scanner.yaml and customize as needed.

scanner:
  # Add variable names that should be excluded from reporting.
  exclude_variable_names:
    - format
    - helperValue

  # Paths that should be skipped during scanning.
  exclude_paths:
    - tool/cache
    - scripts/generated

  # Extra keywords that should trigger MASVS-style context detection.
  context_keywords:
    - firebase_token
    - digicert_cert
